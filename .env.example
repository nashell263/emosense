# Server Port
PORT=3001

# AI API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Vonage SMS & Voice API
VONAGE_API_KEY=your_vonage_api_key_here
VONAGE_API_SECRET=your_vonage_api_secret_here
# The virtual number you bought on Vonage (must include country code, no +)
VONAGE_FROM_NUMBER=1234567890
# Your personal phone number to receive SOS alerts (must include country code, no +)
VONAGE_TO_NUMBER=0987654321

# JWT Secret for Counselor Auth
JWT_SECRET=emosense_super_secret_key_change_in_production
